programa {
  funcao inicio() {
    real valorDepositado, rendimento, total
  
   escreva("Qual o valor depositado:")
   leia(valorDepositado)

   rendimento = valorDepositado * 0.007

   total = valorDepositado + rendimento

   escreva("Com o valor depositado mais o rendimento durante 1 mês é: R$ ",total)


  }
}
