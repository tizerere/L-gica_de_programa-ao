programa {
  funcao inicio() {
    inteiro soma, diferenca, multiplicacao, numero[4] = {5, 7, 9, 20}

     soma = numero[0] + numero[3]
     multiplicacao = numero[1] * numero[2]
     diferenca = numero[2] - numero[0] 

     escreva("A soma é: ", soma, "\n", "A multiplicação é: ", multiplicacao, "\n", "A diferença é: ", diferenca)

  }
}
