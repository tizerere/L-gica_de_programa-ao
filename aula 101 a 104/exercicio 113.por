programa {
  funcao inicio() {
    inteiro valores [5]
    
    escreva("\nInforme o primeiro valor: ")
    leia(valores[0])
     escreva("\nInforme o segundo valor: ")
    leia(valores [1]) 
     escreva("\nInforme o primeiro valor: ")
    leia(valores [2])
    valores [3] = 5 
    valores [4] = 2 

    escreva(valores [0],"\n")
    escreva(valores[1],"\n")
    escreva(valores [2],"\n")
    escreva(valores [3],"\n")
    escreva(valores [4])
    
  }
}
